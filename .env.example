GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public base URL of this server (used to build the OAuth2 redirect URI)
SERVER_BASE_URL=http://localhost:3000
# HTTP port for the OAuth2 redirect server
PORT=3000
# Directory where per-tenant OAuth2 token files are stored
TOKENS_DIR=.tokens
DEDUPE_STORE_PATH=dedupe-store.json
