{
  "name": "mcp-yt-thumbnailer",
  "version": "1.1.0",
  "description": "MCP server for setting YouTube video thumbnails",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "googleapis": "^144.0.0",
    "proper-lockfile": "^4.1.2",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/proper-lockfile": "^4.1.4",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.4",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": false,
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 50,
        "branches": 45,
        "functions": 50,
        "lines": 50
      }
    },
    "forceExit": true
  }
}
